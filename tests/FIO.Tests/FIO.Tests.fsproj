<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <IsPackable>false</IsPackable>
        <IsTestProject>true</IsTestProject>
        <WarningsAsErrors>true</WarningsAsErrors>
        <GenerateProgramFile>false</GenerateProgramFile>
    </PropertyGroup>


    <ItemGroup>
        <!-- Utils -->
        <Compile Include="Utils/Utilities.fs" />

        <!-- DSL -->
        <Compile Include="DSL/CETests.fs" />
        <Compile Include="DSL/ChannelTests.fs" />
        <Compile Include="DSL/ExtensionTests.fs" />
        <Compile Include="DSL/FactoryTests.fs" />
        <Compile Include="DSL/FiberTests.fs" />
        <Compile Include="DSL/CancellationTokenTests.fs" />
        <Compile Include="DSL/FIOTests.fs" />
        <Compile Include="DSL/OperatorTests.fs" />

        <!-- Lib -->
        <Compile Include="Lib/ConsoleTests.fs" />

        <!-- Framework -->
        <Compile Include="Framework/AppTests.fs" />

        <Compile Include="Program.fs" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\FIO\FIO.fsproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="coverlet.collector" Version="10.0.1">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
        <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.6.0" />
        <PackageReference Include="Expecto" Version="10.2.3" />
        <PackageReference Include="Expecto.FsCheck" Version="10.2.3" />
        <PackageReference Include="FsCheck" Version="2.16.6" />
        <PackageReference Include="YoloDev.Expecto.TestSdk" Version="0.15.6" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Update="FSharp.Core" Version="10.1.301" />
    </ItemGroup>

</Project>
