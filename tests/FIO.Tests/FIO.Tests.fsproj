<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <IsPackable>false</IsPackable>
        <IsTestProject>true</IsTestProject>
        <WarningsAsErrors>true</WarningsAsErrors>
        <GenerateProgramFile>false</GenerateProgramFile>
    </PropertyGroup>

    <PropertyGroup>
        <LangVersion>preview</LangVersion>
        <ParallelCompilation>true</ParallelCompilation>
        <Deterministic>false</Deterministic>
    </PropertyGroup>

    <ItemGroup>
        <!-- Utils -->
        <Compile Include="Utils/Utilities.fs" />
        <Compile Include="Utils/MockConsoleBackend.fs" />

        <!-- DSL -->
        <Compile Include="DSL/CETests.fs" />
        <Compile Include="DSL/ChannelTests.fs" />
        <Compile Include="DSL/ExtensionTests.fs" />
        <Compile Include="DSL/FactoryTests.fs" />
        <Compile Include="DSL/FiberTests.fs" />
        <Compile Include="DSL/FIOTests.fs" />
        <Compile Include="DSL/OperatorTests.fs" />

        <!-- Lib -->
        <Compile Include="Lib/ClockTests.fs" />
        <Compile Include="Lib/ConsoleTests.fs" />
        <Compile Include="Lib/EnvironmentTests.fs" />
<!--
        <Compile Include="Lib/PromiseTests.fs" />
        <Compile Include="Lib/RandomTests.fs" />
        <Compile Include="Lib/RefTests.fs" />
        <Compile Include="Lib/SemaphoreTests.fs" />
-->

        <!-- Framework -->
<!--
        <Compile Include="Framework/AppTests.fs" />
-->

        <!-- Cross-cutting -->
<!--
        <Compile Include="Runtime/RuntimeTests.fs" />
        <Compile Include="LawsTests.fs" />
-->

        <Compile Include="Program.fs" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\FIO\FIO.fsproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="coverlet.collector" Version="8.0.1">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
        <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.3.0" />
        <PackageReference Include="Expecto" Version="10.2.3" />
        <PackageReference Include="Expecto.FsCheck" Version="10.2.3" />
        <PackageReference Include="FsCheck" Version="2.16.6" />
        <PackageReference Include="YoloDev.Expecto.TestSdk" Version="0.15.5" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Update="FSharp.Core" Version="10.1.201" />
    </ItemGroup>

</Project>
